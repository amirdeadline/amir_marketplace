{
  "marketplace": "amir-marketplace",
  "version": "0.2.0",
  "updated_at": "2026-07-14",
  "plugins": [
    {
      "name": "amir",
      "path": "./plugins/amir",
      "source_of_truth": "../Amir",
      "pack": "node scripts/pack-amir.js"
    },
    {
      "name": "amir-asana",
      "path": "./plugins/amir-asana",
      "source_of_truth": "../asana/Amir_Asana_Claude",
      "pack": "node scripts/pack-amir-asana.js"
    },
    {
      "name": "prisma",
      "path": "./plugins/prisma",
      "source_of_truth": "../prisma",
      "pack": "python ../prisma/scripts/ingest.py && node scripts/pack-plugin-copy.js --name prisma"
    },
    {
      "name": "litellm",
      "path": "./plugins/litellm",
      "source_of_truth": "../litellm",
      "pack": "node scripts/pack-plugin-copy.js --name litellm"
    }
  ],
  "hosts": [
    {
      "id": "claude-code",
      "display_name": "Claude Code",
      "marketplace_manifest": ".claude-plugin/marketplace.json",
      "install": [
        "/plugin marketplace add <path-or-owner/repo>",
        "/plugin install amir@amir-marketplace",
        "/plugin install amir-asana@amir-marketplace",
        "/plugin install prisma@amir-marketplace",
        "/plugin install litellm@amir-marketplace"
      ],
      "supports": { "native_subagents": true, "btw": false, "hooks": true, "slash_commands": true },
      "notes": "prisma is INTERNAL (PANW docs). Keep marketplace private if prisma is included."
    },
    {
      "id": "cursor",
      "display_name": "Cursor",
      "marketplace_manifest": ".cursor-plugin/marketplace.json",
      "install": [
        "powershell -ExecutionPolicy Bypass -File scripts/install-cursor-local.ps1",
        "Developer: Reload Window"
      ],
      "supports": { "native_subagents": false, "btw": true, "hooks": "limited", "slash_commands": true },
      "notes": "Local junctions under ~/.cursor/plugins/local/"
    },
    {
      "id": "codex",
      "display_name": "OpenAI Codex CLI / ChatGPT Codex",
      "marketplace_manifest": ".agents/plugins/marketplace.json",
      "install": [
        "codex plugin marketplace add <path-or-owner/repo>",
        "codex plugin add amir",
        "codex plugin add amir-asana",
        "codex plugin add prisma",
        "codex plugin add litellm"
      ],
      "supports": { "native_subagents": false, "btw": true, "hooks": "limited", "slash_commands": "deprecated — use skills" }
    },
    {
      "id": "agent-skills",
      "display_name": "Agent Skills compatible hosts",
      "marketplace_manifest": "catalog/hosts.json",
      "install": [
        "Copy skills from plugins/<name>/skills into the host skills directory"
      ],
      "supports": { "native_subagents": "host-dependent", "btw": "host-dependent", "hooks": "host-dependent", "slash_commands": "host-dependent" }
    }
  ]
}
