{
  "$id": "approvals.schema.json",
  "type": "object",
  "required": ["version", "approvals"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "summary", "requested_at", "outcome", "decided_at", "decided_by"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": [
              "budget_extension",
              "architecture",
              "security",
              "destructive",
              "behavior_change"
            ]
          },
          "summary": { "type": "string" },
          "requested_at": { "type": "string" },
          "task": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
          "justification": { "oneOf": [{ "type": "string" }, { "type": "null" }, { "type": "object" }] },
          "outcome": { "type": "string", "enum": ["approved", "rejected"] },
          "decided_at": { "type": "string" },
          "decided_by": { "type": "string" },
          "grants": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
          "note": { "oneOf": [{ "type": "string" }, { "type": "null" }] }
        }
      }
    }
  }
}
