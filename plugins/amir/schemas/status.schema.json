{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://amir.plugin/schemas/status.schema.json",
  "title": "amir status.json",
  "description": "Dashboard state for ai/state/status.json (Section 5.2). Tools may populate a subset; unused optional fields may be omitted.",
  "type": "object",
  "required": ["pending_approvals"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "ts": { "type": "string" },
    "phase": { "type": "string" },
    "overall": {
      "type": "string",
      "enum": [
        "not_started",
        "discovery",
        "planning",
        "implementing",
        "qa",
        "fixing",
        "blocked",
        "complete"
      ]
    },
    "current_task": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
    "current_phase": {
      "type": "string",
      "enum": [
        "discovery",
        "architecture",
        "planning",
        "dev",
        "qa",
        "fix",
        "goal_alignment",
        "blocked",
        "complete"
      ]
    },
    "latest_result": { "type": "string" },
    "next_action": { "type": "string" },
    "blocker": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "last_qa": {
      "type": "string",
      "enum": ["not_run", "pass", "pass_with_warnings", "fail", "blocked"]
    },
    "goal_alignment": {
      "type": "string",
      "enum": ["preserved", "drift_risk", "failed", "not_checked"]
    },
    "files_changed_this_iteration": {
      "type": "array",
      "items": { "type": "string" }
    },
    "pending_approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "summary", "requested_at"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": [
              "budget_extension",
              "architecture",
              "security",
              "destructive",
              "behavior_change"
            ]
          },
          "task": { "type": "string" },
          "summary": { "type": "string" },
          "requested_at": { "type": "string" }
        }
      }
    },
    "progress": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "tasks_total": { "type": "integer", "minimum": 0 },
        "tasks_complete": { "type": "integer", "minimum": 0 },
        "percent": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "dashboard": { "type": "object" },
    "risks_summary": { "type": "object" }
  }
}
