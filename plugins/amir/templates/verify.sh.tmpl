#!/usr/bin/env bash
# verify.sh — Project verification script for {{PROJECT_NAME}}
# Generated from templates/verify.sh.tmpl
# Run from project root: ./verify.sh

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$PROJECT_ROOT"

echo "========================================"
echo " verify.sh — {{PROJECT_NAME}}"
echo " Project root: $PROJECT_ROOT"
echo " Started: $(date -u +"%Y-%m-%dT%H:%M:%SZ")"
echo "========================================"
echo ""

run_section() {
  local name="$1"
  local cmd="$2"
  echo "----------------------------------------"
  echo " SECTION: $name"
  echo " Command: $cmd"
  echo "----------------------------------------"
  if ! eval "$cmd"; then
    echo ""
    echo "FAILED: $name"
    echo "Command exited non-zero: $cmd"
    exit 1
  fi
  echo ""
  echo "PASSED: $name"
  echo ""
}

# --- Lint ---
run_section "Lint" "{{LINT_CMD}}"

# --- Build ---
run_section "Build" "{{BUILD_CMD}}"

# --- Test ---
run_section "Test" "{{TEST_CMD}}"

echo "========================================"
echo " ALL SECTIONS PASSED"
echo " Finished: $(date -u +"%Y-%m-%dT%H:%M:%SZ")"
echo "========================================"
exit 0
