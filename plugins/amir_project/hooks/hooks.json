{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/tools/secrets_scan.js\" ."
          }
        ]
      },
      {
        "matcher": "Bash|Shell",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/terraform/hook_block_tf.py\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"amir: secrets PreToolUse hook active on Bash; primary gate is git commit via security_scan / git_commit skill flow.\""
          }
        ]
      }
    ]
  }
}
