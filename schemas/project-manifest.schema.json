{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amir-marketplace.local/schemas/project-manifest.schema.json",
  "title": "Amir project manifest (.amir/project.yaml)",
  "description": "Schema version 2 of the per-project Amir manifest. Declares hosts, selected amir_project component groups, system capability grants, project tool configuration, and permission policy. Selection here is the single source of truth for what is enabled in a project.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "project", "hosts", "plugins"],
  "properties": {
    "schema_version": {
      "const": 2,
      "description": "Manifest schema version. This schema validates version 2 only."
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "root"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]{0,63}$",
          "description": "Stable machine id (lowercase, digits, underscore, hyphen)."
        },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "root": {
          "type": "string",
          "minLength": 1,
          "description": "Absolute path of the project root on this machine."
        },
        "created_at": { "type": "string", "description": "ISO-8601 timestamp." },
        "onboarded": {
          "type": "boolean",
          "description": "true when the project was adopted via /amir:onboard_project rather than created fresh."
        }
      }
    },
    "hosts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cursor": { "$ref": "#/$defs/enabledToggle" },
        "claude_code": { "$ref": "#/$defs/enabledToggle" }
      }
    },
    "plugins": {
      "type": "object",
      "additionalProperties": false,
      "required": ["amir_project"],
      "properties": {
        "amir_project": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "components": {
              "type": "array",
              "uniqueItems": true,
              "items": { "type": "string", "pattern": "^[a-z0-9_]+$" },
              "description": "Selected amir_project component group ids (see catalog/catalog.json)."
            }
          }
        }
      }
    },
    "system_capabilities": {
      "type": "object",
      "additionalProperties": false,
      "description": "Grants for user-scope (amir_system) integrations. Installed at user scope does NOT mean allowed in this project.",
      "properties": {
        "asana": { "$ref": "#/$defs/allowedToggle" },
        "playwright": { "$ref": "#/$defs/allowedToggle" }
      }
    },
    "project_tools": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "graphify": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "output_directory": { "type": "string", "default": "graphify-out" },
            "update_policy": {
              "type": "string",
              "enum": [
                "manual",
                "after-major-change",
                "before-impact-analysis",
                "before-architecture-task",
                "before-code-review",
                "after-git-commit"
              ],
              "default": "manual"
            },
            "include": { "type": "array", "items": { "type": "string" } },
            "exclude": { "type": "array", "items": { "type": "string" } },
            "commit_generated_graph": { "type": "boolean", "default": false }
          }
        },
        "serena": { "$ref": "#/$defs/enabledToggle" },
        "context7": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "mode": { "type": "string", "enum": ["mcp", "cli"], "default": "mcp" }
          }
        },
        "semgrep": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "integration": {
              "type": "string",
              "enum": ["guardian", "mcp", "both"],
              "default": "mcp"
            },
            "policy": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "scan_changed_files": { "type": "boolean", "default": true },
                "scan_before_commit": { "type": "boolean", "default": false },
                "block_on": {
                  "type": "array",
                  "uniqueItems": true,
                  "items": {
                    "type": "string",
                    "enum": ["critical", "high", "medium", "low"]
                  },
                  "default": ["critical", "high"],
                  "description": "Severity levels that fail the security gate. Not enforced without project approval."
                },
                "scan_secrets": { "type": "boolean", "default": true },
                "scan_dependencies": { "type": "boolean", "default": false }
              }
            }
          }
        },
        "langfuse": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "mode": {
              "type": "string",
              "enum": ["hosted", "self_hosted", "disabled"],
              "default": "disabled"
            }
          }
        },
        "openhands": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "sandbox": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "project_mount": {
                  "type": "string",
                  "enum": ["read_only", "read_write"],
                  "default": "read_write"
                },
                "home_mount": { "const": false, "default": false, "description": "Home directory must never be mounted into the sandbox." },
                "privileged": { "const": false, "default": false, "description": "Privileged containers are not permitted." },
                "network": {
                  "type": "string",
                  "enum": ["disabled", "enabled"],
                  "default": "disabled"
                },
                "credentials": { "const": "none", "default": "none", "description": "No credential forwarding into the sandbox." }
              }
            }
          }
        },
        "git_worktrees": { "$ref": "#/$defs/enabledToggle" },
        "swe_bench": { "$ref": "#/$defs/enabledToggle" },
        "terminal_bench": { "$ref": "#/$defs/enabledToggle" }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "network": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "default": { "type": "string", "enum": ["deny", "allow"], "default": "deny" },
            "allowed_components": {
              "type": "array",
              "uniqueItems": true,
              "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
            }
          }
        },
        "secrets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "default": { "type": "string", "enum": ["deny", "allow"], "default": "deny" },
            "allowed_references": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^[A-Z][A-Z0-9_]*$",
                "description": "Environment variable NAMES only. Secret values must never appear in the manifest."
              }
            }
          }
        },
        "destructive_actions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "require_confirmation": { "type": "boolean", "default": true }
          }
        }
      }
    },
    "documentation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "files": {
          "type": "object",
          "description": "Map of documentation role (status, tasks, decisions, risks, context_handoff, architecture, ...) to a project-relative path.",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "generated_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commit_graphify_output": { "type": "boolean", "default": false },
        "commit_playwright_artifacts": { "type": "boolean", "default": false },
        "commit_benchmark_results": { "type": "boolean", "default": false }
      }
    }
  },
  "$defs": {
    "enabledToggle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": { "enabled": { "type": "boolean" } }
    },
    "allowedToggle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed"],
      "properties": { "allowed": { "type": "boolean" } }
    }
  }
}
